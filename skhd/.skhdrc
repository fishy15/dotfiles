# switch between open windows
alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east

# swap open windows
alt + shift - h : yabai -m window --swap west
alt + shift - j : yabai -m window --swap south
alt + shift - k : yabai -m window --swap north
alt + shift - l : yabai -m window --swap east
alt + ctrl - h : yabai -m window --warp west
alt + ctrl - j : yabai -m window --warp south
alt + ctrl - k : yabai -m window --warp north
alt + ctrl - l : yabai -m window --warp east
alt - r : yabai -m space --rotate 90
alt + shift - r : yabai -m space --rotate 270

# resize windows
alt - u : yabai -m window --resize left:-40:0
alt + shift - u : yabai -m window --resize left:40:0
alt - i : yabai -m window --resize bottom:0:40
alt + shift - i : yabai -m window --resize bottom:-40
alt - o : yabai -m window --resize top:0:-40
alt + shift - o : yabai -m window --resize top:0:40
alt - p : yabai -m window --resize right:40:0
alt + shift - p : yabai -m window --resize right:-40:0

# switch displays
alt - s : yabai -m display --focus next || yabai -m display --focus first
# alt + shift - s : yabai -m display --focus prev || yabai -m display --focus last

# adjust window sizes
alt - b : yabai -m space --balance
alt - f : yabai -m window --toggle zoom-fullscreen
alt + shift - f : yabai -m window --toggle zoom-parent

# toggle mode
alt - m : yabai -m config layout bsp
alt + shift - m : yabai -m config layout float

.blacklist [
    "emacs"
]
